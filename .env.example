# AM4 God Bot — Environment Variables
# Copy this file to .env and fill in your credentials

# Your Airline Manager 4 login credentials
AM4_EMAIL=your_email@example.com
AM4_PASSWORD=your_password_here

# Bot Configuration
FUEL_THRESHOLD=500
CO2_THRESHOLD=120
DEPART_INTERVAL_MIN=270000
DEPART_INTERVAL_MAX=330000
MIN_BANK_BALANCE=500000
MAINTENANCE_WEAR_THRESHOLD=50
NIGHT_PAUSE_START=2
NIGHT_PAUSE_END=5
SCAN_INTERVAL=900000

# Dashboard
PORT=3000
DASHBOARD_PASSWORD=changeme123

# Set to 'true' to run Puppeteer in non-headless mode (local dev only)
HEADLESS=true
